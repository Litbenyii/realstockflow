generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MovimientoStock {
  id               Int            @id @default(autoincrement())
  tipo             TipoMovimiento
  cantidad         Int
  descripcion      String?
  creadoEn         DateTime       @default(now())
  varianteId       Int
  tiendaId         Int
  usuarioId        Int
  origenUbicacion  Ubicacion?
  destinoUbicacion Ubicacion?
  Tienda           Tienda         @relation(fields: [tiendaId], references: [id])
  Usuario          Usuario        @relation(fields: [usuarioId], references: [id])
  Variante         Variante       @relation(fields: [varianteId], references: [id])
}

model Producto {
  id          Int        @id @default(autoincrement())
  nombre      String
  codigo      String     @unique
  categoria   Categoria
  descripcion String?
  activo      Boolean    @default(true)
  creadoEn    DateTime   @default(now())
  tiendaId    Int
  Tienda      Tienda     @relation(fields: [tiendaId], references: [id])
  Variante    Variante[]
}

model Reporte {
  id        Int         @id @default(autoincrement())
  tipo      TipoReporte
  nombre    String
  url       String?
  creadoEn  DateTime    @default(now())
  tiendaId  Int
  usuarioId Int
  Tienda    Tienda      @relation(fields: [tiendaId], references: [id])
  Usuario   Usuario     @relation(fields: [usuarioId], references: [id])
}

model Stock {
  id            Int       @id @default(autoincrement())
  cantidad      Int       @default(0)
  ubicacion     Ubicacion
  actualizadoEn DateTime
  varianteId    Int
  tiendaId      Int
  Tienda        Tienda    @relation(fields: [tiendaId], references: [id])
  Variante      Variante  @relation(fields: [varianteId], references: [id])

  @@unique([varianteId, tiendaId, ubicacion])
}

model Tienda {
  id              Int               @id @default(autoincrement())
  nombre          String
  direccion       String?
  ciudad          String?
  activa          Boolean           @default(true)
  creadoEn        DateTime          @default(now())
  MovimientoStock MovimientoStock[]
  Producto        Producto[]
  Reporte         Reporte[]
  Stock           Stock[]
  Usuario         Usuario[]
}

model Usuario {
  id              Int               @id @default(autoincrement())
  nombre          String
  email           String            @unique
  password        String
  rol             Rol
  activo          Boolean           @default(true)
  creadoEn        DateTime          @default(now())
  tiendaId        Int
  MovimientoStock MovimientoStock[]
  Reporte         Reporte[]
  Tienda          Tienda            @relation(fields: [tiendaId], references: [id])
}

model Variante {
  id              Int               @id @default(autoincrement())
  talla           String
  color           String?
  sku             String            @unique
  creadoEn        DateTime          @default(now())
  productoId      Int
  MovimientoStock MovimientoStock[]
  Stock           Stock[]
  Producto        Producto          @relation(fields: [productoId], references: [id])
}

enum Categoria {
  HOMBRE
  MUJER
  NINO
  NINA
  JUVENIL
  DENIM
  LENCERIA
  ACCESORIOS
  OTRO
}

enum Rol {
  JEFATURA
  BODEGUERO
  CAJERO
}

enum TipoMovimiento {
  INGRESO
  TRASLADO
  VENTA
  DEVOLUCION
  AJUSTE
}

enum TipoReporte {
  INVENTARIO
  MOVIMIENTOS
  CRITICOS
  PEDIDO
}

enum Ubicacion {
  BODEGA
  TIENDA
}
