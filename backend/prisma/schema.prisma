generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tienda {
  id        Int      @id @default(autoincrement())
  nombre    String
  direccion String?
  ciudad    String?
  activa    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  Usuario         Usuario[]
  Producto        Producto[]
  Stock           Stock[]
  MovimientoStock MovimientoStock[]
  Reporte         Reporte[]
}

enum Rol {
  JEFATURA
  BODEGUERO
  CAJERO
}

model Usuario {
  id       Int      @id @default(autoincrement())
  nombre   String
  rut      String   @unique
  email    String   @unique
  password String
  rol      Rol
  activo   Boolean  @default(true)
  creadoEn DateTime @default(now())

  tiendaId        Int
  Tienda          Tienda            @relation(fields: [tiendaId], references: [id])
  MovimientoStock MovimientoStock[]
  Reporte         Reporte[]
}

enum Categoria {
  NINO
  NINA
  DENIM_HOMBRE
  DENIM_MUJER
  LENCERIA
  ROPA_INTERIOR
  JUVENIL_HOMBRE
  JUVENIL_MUJER
  SENORA
  MUJER
  HOMBRE_CASUAL
  HOME
}

model Producto {
  id          Int       @id @default(autoincrement())
  nombre      String
  codigo      String    @unique
  categoria   Categoria
  descripcion String?
  activo      Boolean   @default(true)
  creadoEn    DateTime  @default(now())

  tiendaId Int
  Tienda   Tienda     @relation(fields: [tiendaId], references: [id])
  Variante Variante[]
}

model Variante {
  id       Int      @id @default(autoincrement())
  talla    String
  color    String?
  sku      String   @unique
  creadoEn DateTime @default(now())

  productoId      Int
  Producto        Producto          @relation(fields: [productoId], references: [id])
  Stock           Stock[]
  MovimientoStock MovimientoStock[]
}

enum Ubicacion {
  BODEGA
  TIENDA
}

model Stock {
  id            Int       @id @default(autoincrement())
  cantidad      Int       @default(0)
  ubicacion     Ubicacion
  actualizadoEn DateTime

  varianteId Int
  tiendaId   Int
  Variante   Variante @relation(fields: [varianteId], references: [id])
  Tienda     Tienda   @relation(fields: [tiendaId], references: [id])

  @@unique([varianteId, tiendaId, ubicacion])
}

enum TipoMovimiento {
  INGRESO
  TRASLADO
  VENTA
  DEVOLUCION
  AJUSTE
}

model MovimientoStock {
  id               Int            @id @default(autoincrement())
  tipo             TipoMovimiento
  cantidad         Int
  descripcion      String?
  creadoEn         DateTime       @default(now())
  origenUbicacion  Ubicacion?
  destinoUbicacion Ubicacion?

  varianteId Int
  tiendaId   Int
  usuarioId  Int
  Variante   Variante @relation(fields: [varianteId], references: [id])
  Tienda     Tienda   @relation(fields: [tiendaId], references: [id])
  Usuario    Usuario  @relation(fields: [usuarioId], references: [id])
}

enum TipoReporte {
  INVENTARIO
  MOVIMIENTOS
  CRITICOS
  PEDIDO
}

model Reporte {
  id       Int         @id @default(autoincrement())
  tipo     TipoReporte
  nombre   String
  url      String?
  creadoEn DateTime    @default(now())

  tiendaId  Int
  usuarioId Int
  Tienda    Tienda  @relation(fields: [tiendaId], references: [id])
  Usuario   Usuario @relation(fields: [usuarioId], references: [id])
}
